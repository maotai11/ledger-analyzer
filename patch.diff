+    if (Number.isFinite(win)) AppState.offset.timeWindowDays = Math.max(0, Math.min(365, win));
+    if (Number.isFinite(kmax)) AppState.offset.subsetMaxK = Math.max(2, Math.min(8, kmax));
+    if (tol != null && dom?.f2Tolerance) dom.f2Tolerance.value = String(tol);
+  } catch { /* ignore */ }
+}
+function persistOffsetSetting(key, value) {
+  try { localStorage.setItem(key, String(value)); } catch { /* ignore */ }
+}
